{% doc %}
  @prompt
    Create a 'Why Tucker-Bloom' section for product pages that highlights the brand's trust signals and story. The section should include:- A heading like "Why Tucker-Bloom"- Three or four icon-based trust signal blocks with short descriptions:  - "Made in USA" – Handcrafted in Nashville, TN since the 1990s  - "Lifetime Warranty" – Built to last, backed by our guarantee  - "Family Owned" – 30  years of bag-making expertise  - "Premium Materials" – Chrome-tanned leather, shock-absorbing foam backing- Clean, minimal layout that fits naturally between the product description and reviews on a product page- Should be a reusable section/block that can be added to any product page template- Style should feel premium and artisan — not flashy, just confident and trustworthy
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-why-brand-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-why-brand-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-why-brand-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    text-align: {{ block.settings.heading_alignment }};
    font-weight: 400;
    letter-spacing: 0.5px;
  }

  .ai-why-brand-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin: 0;
  }

  .ai-why-brand-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.item_alignment }};
    text-align: {{ block.settings.item_alignment }};
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.item_background_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
    transition: transform 0.2s ease;
  }

  {% if block.settings.enable_hover_effect %}
    .ai-why-brand-item-{{ ai_gen_id }}:hover {
      transform: translateY(-4px);
    }
  {% endif %}

  .ai-why-brand-icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin-bottom: {{ block.settings.icon_spacing }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ai-why-brand-icon-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    color: {{ block.settings.icon_color }};
  }

  .ai-why-brand-item-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.item_title_size }}px;
    color: {{ block.settings.item_title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    font-weight: 600;
    letter-spacing: 0.3px;
  }

  .ai-why-brand-item-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.item_text_size }}px;
    color: {{ block.settings.item_text_color }};
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 768px) {
    .ai-why-brand-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.75 }}px;
    }

    .ai-why-brand-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-why-brand-icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.85 }}px;
      height: {{ block.settings.icon_size | times: 0.85 }}px;
    }

    .ai-why-brand-item-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.item_title_size | times: 0.9 }}px;
    }

    .ai-why-brand-item-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.item_text_size | times: 0.95 }}px;
    }
  }
{% endstyle %}

<why-brand-{{ ai_gen_id }} class="ai-why-brand-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-why-brand-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-why-brand-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-why-brand-grid-{{ ai_gen_id }}">
      {% if block.settings.item_1_enabled %}
        <div class="ai-why-brand-item-{{ ai_gen_id }}">
          <div class="ai-why-brand-icon-wrapper-{{ ai_gen_id }}">
            <svg class="ai-why-brand-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 3h18v18H3z"/>
              <path d="M3 9h18"/>
              <path d="M9 21V9"/>
            </svg>
          </div>
          {% if block.settings.item_1_title != blank %}
            <h3 class="ai-why-brand-item-title-{{ ai_gen_id }}">{{ block.settings.item_1_title }}</h3>
          {% endif %}
          {% if block.settings.item_1_text != blank %}
            <div class="ai-why-brand-item-text-{{ ai_gen_id }}">{{ block.settings.item_1_text }}</div>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.item_2_enabled %}
        <div class="ai-why-brand-item-{{ ai_gen_id }}">
          <div class="ai-why-brand-icon-wrapper-{{ ai_gen_id }}">
            <svg class="ai-why-brand-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 6v6l4 2"/>
            </svg>
          </div>
          {% if block.settings.item_2_title != blank %}
            <h3 class="ai-why-brand-item-title-{{ ai_gen_id }}">{{ block.settings.item_2_title }}</h3>
          {% endif %}
          {% if block.settings.item_2_text != blank %}
            <div class="ai-why-brand-item-text-{{ ai_gen_id }}">{{ block.settings.item_2_text }}</div>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.item_3_enabled %}
        <div class="ai-why-brand-item-{{ ai_gen_id }}">
          <div class="ai-why-brand-icon-wrapper-{{ ai_gen_id }}">
            <svg class="ai-why-brand-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          {% if block.settings.item_3_title != blank %}
            <h3 class="ai-why-brand-item-title-{{ ai_gen_id }}">{{ block.settings.item_3_title }}</h3>
          {% endif %}
          {% if block.settings.item_3_text != blank %}
            <div class="ai-why-brand-item-text-{{ ai_gen_id }}">{{ block.settings.item_3_text }}</div>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.item_4_enabled %}
        <div class="ai-why-brand-item-{{ ai_gen_id }}">
          <div class="ai-why-brand-icon-wrapper-{{ ai_gen_id }}">
            <svg class="ai-why-brand-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          {% if block.settings.item_4_title != blank %}
            <h3 class="ai-why-brand-item-title-{{ ai_gen_id }}">{{ block.settings.item_4_title }}</h3>
          {% endif %}
          {% if block.settings.item_4_text != blank %}
            <div class="ai-why-brand-item-text-{{ ai_gen_id }}">{{ block.settings.item_4_text }}</div>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</why-brand-{{ ai_gen_id }}>

<script>
  (function() {
    class WhyBrand{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.items = this.querySelectorAll('.ai-why-brand-item-{{ ai_gen_id }}');
        this.observeItems();
      }

      observeItems() {
        if ('IntersectionObserver' in window) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.style.opacity = '1';
                entry.target.style.transform = 'translateY(0)';
              }
            });
          }, {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
          });

          this.items.forEach((item, index) => {
            item.style.opacity = '0';
            item.style.transform = 'translateY(20px)';
            item.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
            item.style.transitionDelay = (index * 0.1) + 's';
            observer.observe(item);
          });
        }
      }
    }

    customElements.define('why-brand-{{ ai_gen_id }}', WhyBrand{{ ai_gen_id }});
  })();
</script>

